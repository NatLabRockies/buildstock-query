[
  {
    "name": "mapped_column_simple_bldg_type_group_by",
    "description": "Annual electricity grouped by a MappedColumn that collapses building types into broader categories, CO only.",
    "sql_file": "mapped_column_simple_bldg_type_group_by.sql",
    "data_file": "mapped_column_simple_bldg_type_group_by.parquet",
    "args": {
      "target": "group_by",
      "mapped_name": "simple_bldg_type",
      "key_column": "$BUILDING_TYPE_COL",
      "mapping_dict": "$BUILDING_TYPE_MAPPING",
      "enduses": ["$ELECTRICITY_TOTAL"],
      "restrict": [["state", ["CO"]]]
    }
  }
]
