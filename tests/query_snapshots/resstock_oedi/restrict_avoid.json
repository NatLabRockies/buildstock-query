[
  {
    "name": "restrict_single_state_CO",
    "description": "Annual electricity restricted to CO with simple single-value restrict.",
    "sql_file": "restrict_single_state_CO.sql",
    "data_file": "restrict_single_state_CO.parquet",
    "args": {
      "enduses": ["out.electricity.total.energy_consumption"],
      "group_by": ["in.geometry_building_type_recs"],
      "restrict": [["in.state", ["CO"]]]
    }
  },
  {
    "name": "restrict_two_states",
    "description": "Annual electricity restricted to CO + WY.",
    "sql_file": "restrict_two_states.sql",
    "data_file": "restrict_two_states.parquet",
    "args": {
      "enduses": ["out.electricity.total.energy_consumption"],
      "group_by": ["in.state"],
      "restrict": [["in.state", ["CO", "WY"]]]
    }
  },
  {
    "name": "restrict_state_plus_vintage",
    "description": "CO + specific vintage bucket, electricity.",
    "sql_file": "restrict_state_plus_vintage.sql",
    "data_file": "restrict_state_plus_vintage.parquet",
    "args": {
      "enduses": ["out.electricity.total.energy_consumption"],
      "group_by": ["in.vintage"],
      "restrict": [["in.state", ["CO"]], ["in.vintage", ["1980s"]]]
    }
  },
  {
    "name": "avoid_mobile_home_CO",
    "description": "CO only, avoid mobile homes.",
    "sql_file": "avoid_mobile_home_CO.sql",
    "data_file": "avoid_mobile_home_CO.parquet",
    "args": {
      "enduses": ["out.electricity.total.energy_consumption"],
      "group_by": ["in.geometry_building_type_recs"],
      "restrict": [["in.state", ["CO"]]],
      "avoid": [["in.geometry_building_type_recs", ["Mobile Home"]]]
    }
  }
]
