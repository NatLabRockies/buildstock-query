[
  {
    "name": "restrict_single_state",
    "description": "Annual electricity restricted to CO. Three equivalent restrict shapes (single-element list, scalar string, scalar wrapped in tuple) must all compile to the same SQL — covers the arg-normalization code path in _get_restrict_clauses.",
    "sql_file": "restrict_single_state.sql",
    "data_file": "restrict_single_state.parquet",
    "args": [
      {
        "enduses": ["$ELECTRICITY_TOTAL"],
        "group_by": ["$BUILDING_TYPE_COL"],
        "restrict": [["state", ["CO"]]]
      },
      {
        "enduses": ["$ELECTRICITY_TOTAL"],
        "group_by": ["$BUILDING_TYPE_COL"],
        "restrict": [["state", "CO"]]
      }
    ]
  },
  {
    "name": "restrict_two_states",
    "description": "Annual electricity restricted to CO + WY.",
    "sql_file": "restrict_two_states.sql",
    "data_file": "restrict_two_states.parquet",
    "args": {
      "enduses": ["$ELECTRICITY_TOTAL"],
      "group_by": ["state"],
      "restrict": [["state", ["CO", "WY"]]]
    }
  },
  {
    "name": "restrict_state_plus_vintage",
    "description": "CO + specific vintage bucket, electricity.",
    "sql_file": "restrict_state_plus_vintage.sql",
    "data_file": "restrict_state_plus_vintage.parquet",
    "args": {
      "enduses": ["$ELECTRICITY_TOTAL"],
      "group_by": ["vintage"],
      "restrict": [["state", ["CO"]], ["vintage", ["$VINTAGE_BUCKET"]]]
    }
  },
  {
    "name": "avoid_building_type",
    "description": "CO only, avoid one building type per schema.",
    "sql_file": "avoid_building_type.sql",
    "data_file": "avoid_building_type.parquet",
    "args": {
      "enduses": ["$ELECTRICITY_TOTAL"],
      "group_by": ["$BUILDING_TYPE_COL"],
      "restrict": [["state", ["CO"]]],
      "avoid": [["$BUILDING_TYPE_COL", ["$AVOID_BUILDING_TYPE"]]]
    }
  },
  {
    "name": "avoid_building_type_multi",
    "description": "CO only, avoid multiple building types via multi-element avoid list — exercises the NOT IN code path in _add_avoid (single-value avoid emits != instead).",
    "sql_file": "avoid_building_type_multi.sql",
    "data_file": "avoid_building_type_multi.parquet",
    "args": {
      "enduses": ["$ELECTRICITY_TOTAL"],
      "group_by": ["$BUILDING_TYPE_COL"],
      "restrict": [["state", ["CO"]]],
      "avoid": [["$BUILDING_TYPE_COL", "$AVOID_BUILDING_TYPES_MULTI"]]
    }
  }
]
